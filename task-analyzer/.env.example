# ─── Task Analyzer — Environment Variables ───

# Server
PORT=3100
HOST=0.0.0.0

# Fernet encryption key for decrypting apiKey / gitPat from clients
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to accept plaintext keys
ENCRYPTION_KEY=

# Debug mode (set to any value to enable verbose logs)
# DEBUG=1

# Node.js memory limit (optional, for large repos)
# NODE_OPTIONS=--max-old-space-size=4096
