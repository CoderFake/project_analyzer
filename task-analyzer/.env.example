# ─── Task Analyzer — Environment Variables ───
# Set via mcpServers env config, .env file, or system env.

# Server
PORT=3100
HOST=0.0.0.0

# ─── LLM Provider ───
# Supported: openai, anthropic, gemini, ollama
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=http://localhost:11434  # Required for Ollama

# ─── Git Credentials (for setup_project tool) ───
GIT_USERNAME=
GIT_PAT=

# ─── Encryption (optional) ───
# Fernet key for decrypting apiKey/gitPat if clients send encrypted values
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# ─── Debug ───
# DEBUG=1
